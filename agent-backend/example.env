# --- Core backend ---
AGENT_BACKEND_PORT=8088
AGENT_MEMORY_FILE=./data/memory.jsonl

# --- LLM connector ---
AGENT_LLM_CONNECTOR=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# --- Web search connector (SerpAPI) ---
SERPAPI_API_KEY=your_serpapi_api_key_here
SERPAPI_ENGINE=google

# --- Gmail OAuth app config ---
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URL=http://localhost:8088/auth/google/callback

# --- Capability gates ---
AGENT_CAPABILITY_WEB_SEARCH=true
AGENT_CAPABILITY_EMAIL=false
AGENT_CAPABILITY_MOBILE_SENSORS=false
AGENT_CAPABILITY_SCREEN_CAPTURE=false
AGENT_CAPABILITY_AUDIO_CAPTURE=false

# --- Logging / observability ---
AGENT_LOG_LEVEL=info
AGENT_LOG_FORMAT=json
AGENT_LOG_EVENTS_ENABLED=true
AGENT_LOG_API_ENABLED=true
AGENT_LOG_INCLUDE_PAYLOAD=false
AGENT_LOG_EVENT_BUFFER=5000
